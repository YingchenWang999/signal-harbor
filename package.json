{
  "name": "signal-harbor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "hardhat test",
    "test:contracts": "hardhat test",
    "compile": "hardhat compile",
    "setup:testnet": "node scripts/setup-testnet.cjs",
    "xrpl:payment": "node scripts/xrpl-payment.cjs",
    "deploy:coston2": "hardhat run scripts/deploy.cjs --network coston2",
    "fdc:evidence": "pnpm fdc:xrp",
    "fdc:xrp": "hardhat run scripts/fdc-xrp-evidence.cjs --network coston2",
    "fdc:evm": "hardhat run scripts/fdc-evm-evidence.cjs --network coston2",
    "audit": "pnpm audit --audit-level high",
    "check": "pnpm lint && pnpm test && pnpm build && pnpm audit"
  },
  "dependencies": {
    "@fontsource-variable/bricolage-grotesque": "5.2.8",
    "@fontsource/dm-mono": "5.2.7",
    "@fontsource-variable/manrope": "5.2.7",
    "@tanstack/react-query": "5.101.1",
    "lucide-react": "0.468.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "viem": "2.55.2"
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "@nomicfoundation/hardhat-ethers": "4.0.15",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "3.0.11",
    "@nomicfoundation/hardhat-mocha": "3.0.21",
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "@types/node": "22.15.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "chai": "6.2.2",
    "eslint": "9.31.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "ethers": "6.17.0",
    "globals": "16.3.0",
    "dotenv": "17.2.3",
    "hardhat": "3.10.0",
    "mocha": "11.7.6",
    "typescript": "5.8.3",
    "typescript-eslint": "8.38.0",
    "vite": "7.3.6",
    "xrpl": "5.0.0"
  },
  "packageManager": "pnpm@11.13.1"
